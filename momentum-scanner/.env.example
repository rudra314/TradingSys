# ── Telegram Bot credentials ─────────────────────────────────────────────────
# Step 1: Open Telegram and search for @BotFather
# Step 2: Send /newbot — follow the prompts to name your bot
# Step 3: Copy the token BotFather gives you (format: 123456789:ABCdef...)
TELEGRAM_TOKEN=your_bot_token_here

# Your Telegram Chat ID (where alerts will be sent)
# Quick way: message @userinfobot on Telegram — it replies with your numeric ID
# For a group: add your bot to the group, then use @RawDataBot to get the group ID
CHAT_ID=your_numeric_chat_id_here

# ── Zerodha Kite Connect (leave blank until you go live) ─────────────────────
# Get credentials from https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
